# =========================
# Docker Compose variables
# =========================
# 
# -------------------------------------------------------
#
# APACHY REVERSE PROXY VIRTUAL HOST HEADER FORWARDING 
# ProxyPreserveHost On
# RequestHeader set X-Forwarded-Proto "https"
# RequestHeader set X-Forwarded-Port  "443"
# RequestHeader set X-Forwarded-Host  "%{HTTP_HOST}s"
#
# ProxyPass        "/"  "http://127.0.0.1:8080/"
# ProxyPassReverse "/"  "http://127.0.0.1:8080/"
#
# --------------------------------------------------------
#
# This file is safe to commit. Copy it to `.env` for local use and fill in secrets.
# `.env` is gitignored.

# -------------------------
# URLs (UCE + Keycloak)
# -------------------------
#
# UCE/Keycloak has different “URL viewpoints”. Using the wrong one is the #1 cause of login/redirect issues.
#
# 1) Browser/Public URL (what the user's browser can reach)
#    - Used for redirects and for Keycloak client's allowed redirect URIs.
#    - Must match DNS/ports/reverse-proxy seen by the browser.
#
# 2) Docker network URL (container-to-container)
#    - Used when one container calls another container inside docker-compose.
#    - Uses compose service names like `uce-keycloak-auth`.
#
# 3) Host-local URL (tools running on the docker host OS)
#    - Usually `http://localhost:<published-port>` on the machine running docker-compose.
#
# 4) Virtual hosts are host names used by nginx-proxy to forward to docker network internal services.
#    - These are only relevant if you start the `nginx` service (profile `proxy`).
#    - When you run without nginx, you can ignore `*_VIRTUAL_HOST`/`*_VIRTUAL_PORT`.
#
# Optional: enable the nginx reverse proxy (nginx-proxy) only when you want virtual-host routing.
# Start it with: `docker compose --profile proxy up -d`
NGINX_PROXY_HTTP_PORT=80

# UCE UI public URL (browser/public). Keycloak redirects back to this app.
# Used by `uce-keycloak-config` to set Keycloak client redirect URIs (it adds `UCE_PUBLIC_URL + "/auth/*"`).
UCE_VIRTUAL_HOST=feedback.core.texttechnologylab.org
UCE_PUBLIC_URL=http://feedback.core.texttechnologylab.org/
KEYCLOAK_VIRTUAL_HOST=auth.feedback.core.texttechnologylab.org

# Keycloak public URL (browser/public). The browser is sent here for login.
UCE_AUTH_PUBLIC_URL=http://auth.feedback.core.texttechnologylab.org/

# Keycloak callback URL in the UCE UI (browser/public).
# Must be allowed in the Keycloak client's "Valid Redirect URIs" (the config job adds `.../auth/*` by default).
UCE_AUTH_REDIRECT_URL=http://feedback.core.texttechnologylab.org/auth

# Reverse proxy (nginx-proxy) host routing is configured via these env vars and injected into the
# `uce-web` and `uce-keycloak-auth` services as `*_VIRTUAL_HOST`/`*_INTERNAL_PORT`.

# Published host port for the `uce-web` container.
UCE_PUBLISHED_PORT=8397
# Internal port that the UCE process binds to inside the container.
UCE_INTERNAL_PORT=4567

# Published host port for the `uce-keycloak-auth` container.
KEYCLOAK_PUBLISHED_PORT=8399
# Internal port that the Keycloak process binds to inside the container.
KEYCLOAK_INTERNAL_PORT=8080

# Keycloak base URL from the UCE backend's point of view (runtime).
# - If UCE runs in docker-compose: use docker network URL, e.g. `http://uce-keycloak-auth:8080`.
# - If UCE runs on the host: use `http://localhost:8080`.
# - If UCE runs elsewhere: use whatever URL that process can reach.
KEYCLOAK_AUTH_SERVER_URL=http://uce-keycloak-auth:8080

# -------------------------
# UCE
# -------------------------

# Usually not needed: override only if you want a different image/tag.
# UCE_WEB_IMAGE=docker.texttechnologylab.org/uce-core-feedback-web:0.1.2

# Host path to the UCE config JSON mounted into the container as `/app/config/uceConfig.json`
UCE_CONFIG_PATH=./uce.portal/uce.common/src/main/resources/defaultUceConfig.json

# UCE auth wiring (uceConfig.json env overrides).
# These settings are consumed by the portal/UI layer to enable auth and to build correct browser redirects.
# They must describe the "public" URLs as seen by the user's browser (not container-internal hostnames).
UCE_AUTH_ENABLED=true

# UCE runtime Keycloak client config (CommonConfig/common.conf overrides).
# This is what the *UCE backend* uses to validate tokens / perform OIDC flows against Keycloak.
# IMPORTANT: This must match the Keycloak client's secret for `KC_CLIENT_ID` (usually `uce-web`).
# The `uce-keycloak-config` helper will also apply this secret to the Keycloak client if it is set.
KEYCLOAK_CREDENTIALS_SECRET=CHANGE_ME

# -------------------------
# Keycloak
# -------------------------

# Usually not needed: override only if you want a different image/tag.
# KEYCLOAK_IMAGE=quay.io/keycloak/keycloak:26.2.5

# Realm import file (imported on Keycloak container startup)
KC_REALM_IMPORT_PATH=./auth/uce-realm.json

# Keycloak bootstrap admin user for the Keycloak container.
# Used for initial Keycloak setup and by the `uce-keycloak-config` helper to log in and patch client settings.
# This is the Keycloak "admin console" user, not an application user.
KC_ADMIN_USERNAME=admin
KC_ADMIN_PW=CHANGE_ME

# `uce-keycloak-config` target realm + client.
# These identify *which* realm and *which* client in Keycloak should be updated (redirect URIs, web origins, etc.).
# - Realm: a Keycloak "tenant"/namespace (e.g. `uce`)
# - Client: the OIDC client representing the UCE web app (e.g. `uce-web`)
KC_REALM=uce
KC_CLIENT_ID=uce-web

# Keycloak URL generation behind reverse proxies (TLS termination).
# If your browser reaches Keycloak via HTTPS through Apache/nginx, Keycloak must trust the forwarded headers
# or it may generate/validate URLs as http:// and complain about SSL/redirects.
#
# Values: forwarded | xforwarded
KC_PROXY_HEADERS=xforwarded
#
# Optional: pin the external hostname Keycloak should advertise (otherwise it derives it from requests).
# Set this to your public Keycloak host, e.g. `auth.feedback.core.texttechnologylab.org`.
# KC_HOSTNAME=

# -------------------------
# Importer
# -------------------------

IMPORTER_THREADS=4

# Importer image/tag (used by the `importer-only` profile)
IMPORTER_IMAGE=docker.texttechnologylab.org/uce-core-feedback-importer:0.1.1

# Importer-only mode (profile `importer-only`):
# - Runs only the importer container and connects to an *external* PostgreSQL via `POSTGRESQL_HIBERNATE_CONNECTION_URL`.
# - Start it with: `docker compose --profile importer-only run --rm uce-importer`
#
# Host folder mounted read-only into the importer as `/app/input`.
IMPORTER_CORPORA_HOST_PATH=./data/importer
#
# Which path inside the container should be treated as the import root (`-src`).
# If you set this, it must point inside the container (default is `/app/input`).
IMPORTER_IMPORT_SRC=/app/input
#
# Importer instance id (must be `1` currently).
IMPORTER_NUMBER=1
#
# Optional: CAS view name (`-view`). Leave empty to use the default view.
# IMPORTER_CAS_VIEW=

# -------------------------
# PostgreSQL
# -------------------------

# Usually not needed: override only if you want a different image/tag or published port.
POSTGRES_IMAGE=docker.texttechnologylab.org/uce/uce-postgresql:0.0.1
POSTGRES_PUBLISHED_PORT=8398

# PostgreSQL bootstrap settings for the DB container (rarely changed).
POSTGRES_DB=uce
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME

# PostgreSQL custom config file (mounted into the DB container)
POSTGRESQL_CONFIG=./database/postgresql.conf

# UCE -> PostgreSQL client (CommonConfig/common.conf overrides)
# Settings UCE requires to communicate with PostgreSQL-DB.
POSTGRESQL_CONNECTION_DRIVER_CLASS=org.postgresql.Driver
POSTGRESQL_DIALECT=org.hibernate.dialect.PostgreSQLDialect
POSTGRESQL_HIBERNATE_CONNECTION_URL=jdbc:postgresql://uce-postgresql-db:5432/uce
POSTGRESQL_HIBERNATE_CURRENT_SESSION_CONTEXT_CLASS=thread
POSTGRESQL_HIBERNATE_SHOW_SQL=false
POSTGRESQL_HIBERNATE_FORMAT_SQL=true
POSTGRESQL_HIBERNATE_HBM2DDL_AUTO=update
POSTGRESQL_ENRICHMENT_LOCATION_MAX=200

# -------------------------
# MinIO
# -------------------------

# MinIO persistent data directory (only relevant if you run the minio service)
# Only needed if you run the (currently commented) MinIO service in docker-compose.
# MINIO_STORAGE_DATA=./data/minio

# UCE -> MinIO client (CommonConfig/common.conf overrides)
# MINIO_ENDPOINT=
# MINIO_USERNAME=
# MINIO_PWD=CHANGE_ME
# MINIO_BUCKET=cas

# -------------------------
# Optional: Fuseki / SPARQL
# -------------------------
#
# Only needed if you enable the commented `uce-fuseki-sparql` service in `docker-compose.yaml`
# or use the tooling in `sparql/*`.
TDB2_DATA=./data/tdb2
TDB2_ENDPOINT=biofid-gbif
# Extra JVM flags passed to the Fuseki JVM (only used by `sparql/entrypoint.sh` / optional service).
JAVA_OPTIONS=

# Used by `sparql/download.sh` for downloading artifacts.
URL=
ARTIFACT_URL=
ARTIFACT_NAME=
CHKSUM_TYPE=
CHKSUMPROG=
CHKSUM_EXT=

# Used in `sparql/Dockerfile` as build args; only relevant if you build that image.
FUSEKI_DIR=/fuseki
FUSEKI_JAR=
KCADM=
REALM=

# -------------------------
# Other CommonConfig overrides
# -------------------------

UCE_VERSION=1.0.4-debug
LOG_DB=false
SESSION_JOB_INTERVAL=3600
SYSTEM_JOB_INTERVAL=10

# Local dev paths
TEMPLATES_LOCATION=/app/uce.portal/resources/templates/
# Host templates folder mounted into the container at the same path as TEMPLATES_LOCATION.
# This enables editing FreeMarker templates without rebuilding the image.
UCE_TEMPLATES_HOST_PATH=./uce.portal/resources/templates
# EXTERNAL_PUBLIC_USE=false
# EXTERNAL_PUBLIC_LOCATION=../uce.web/src/main/resources/public
DATABASE_SCRIPTS_LOCATION=/app/database/

# External integrations
UNIVERSITY_BOTANIK_BASE_URL=https://sammlungen.ub.uni-frankfurt.de/botanik/periodical/titleinfo/{ID}
UNIVERSITY_COLLECTION_BASE_URL=https://sammlungen.ub.uni-frankfurt.de
GBIF_OCCURRENCES_SEARCH_URL=https://api.gbif.org/v1/occurrence/search?limit=10&media_type=stillImage&taxon_key={TAXON_ID}
RAG_WEBSERVER_BASE_URL=http://localhost:5678/
SPARQL_HOST=http://localhost:3030/
SPARQL_ENDPOINT=biofid-gbif/sparql
SPARQL_MAX_ENRICHMENT=100

# -------------------------
# Optional: Keycloak container settings
# -------------------------
#
# Optional: Keycloak container runtime flags (rarely needed).
# KEYCLOAK_START_CMD=start
# KEYCLOAK_FEATURES=scripts
# KEYCLOAK_IMPORT_PATH=/opt/keycloak/data/import/uce-realm.json
# KC_HOSTNAME_STRICT_BACKCHANNEL=true
# KC_HOSTNAME_STRICT=false
# KC_HTTP_RELATIVE_PATH=/
# KC_HTTP_ENABLED=true
# KC_HEALTH_ENABLED=true
# KC_METRICS_ENABLED=true

# Persist Keycloak state (incl. embedded DB) on the host so it survives container recreation.
KEYCLOAK_DATA_HOST_PATH=./data/keycloak

# -------------------------
# Optional: Keycloak user/group sync from CSV
# -------------------------
#
# One-shot helper that creates/updates Keycloak users/groups from a CSV file.
# Enable it via:
# - `docker compose --profile keycloak-sync run --rm uce-keycloak-sync-from-csv`
#
# Docker image for the sync job (baked-in `deploy/keycloak-sync-from-csv.py`).
# Uncomment if you want to pin/override the image/tag.
# KEYCLOAK_SYNC_IMAGE=docker.texttechnologylab.org/uce-core-feedback-keycloak-sync-from-csv:0.1.1
#
# Host path to your CSV file (read-only mounted into the container).
KEYCLOAK_SYNC_CSV_PATH_HOST=./principals.csv
# Container path where the CSV will be available (also passed as CSV_PATH env var).
KEYCLOAK_SYNC_CSV_PATH_CONTAINER=/data/principals.csv
#
# Optional toggles:
# KEYCLOAK_SYNC_DRY_RUN=true
# Limit how many CSV rows to process (excluding the header). Useful for DRY_RUN sanity checks.
# KEYCLOAK_SYNC_MAX_ROWS=20
# KEYCLOAK_SYNC_CREATE_GROUPS=true
# KEYCLOAK_SYNC_CREATE_USERS=true
# KEYCLOAK_SYNC_UPDATE_USERS=true

# -------------------------
# Optional: `uce-keycloak-config` settings
# -------------------------

# Keycloak base URL from the `uce-keycloak-config` helper's point of view (docker network URL by default).
# Leave empty to use the compose default `http://uce-keycloak-auth:8080`.
# KC_BASE_URL=

# Keycloak management URL used for health/readiness checks (docker network URL by default).
# Leave empty to use/derive the compose default `http://uce-keycloak-auth:9000`.
# KC_MGMT_URL=

# Optional: helper-script variables (not required for normal docker-compose usage).
# The scripts in `auth/CORE-feedback-scripts/*` now prefer the existing standard variables:
# - Keycloak URL: `KEYCLOAK_AUTH_SERVER_URL` (or `UCE_AUTH_PUBLIC_URL`)
# - Admin creds: `KC_ADMIN_USERNAME` / `KC_ADMIN_PW`
# - Realm/client: `KEYCLOAK_REALM` / `KEYCLOAK_CLIENT` (or `KC_REALM` / `KC_CLIENT_ID`)
# - Redirect: `UCE_AUTH_REDIRECT_URL`
#
# The variables below are legacy/optional fallbacks only (set them only if you need to override script behavior).
# (Leave empty unless you know you need them; scripts will derive from `KEYCLOAK_AUTH_SERVER_URL` /
# `UCE_AUTH_PUBLIC_URL`, `KC_ADMIN_*`, `KEYCLOAK_*`, and `UCE_AUTH_REDIRECT_URL`.)
# KEYCLOAK_URL=
# ADMIN_REALM=
# ADMIN_USER=
# ADMIN_PASSWORD=
# CLIENT_ID=
# LOGIN_BASE=
# REDIRECT_URI=

# Docker image used for the `uce-keycloak-config` helper container (runs the baked-in keycloak config script).
# Build it from `deploy/keycloak-config.Dockerfile` and push it to your registry.
# Usually not needed unless you run/publish the helper as a separate image.
# KEYCLOAK_CONFIG_IMAGE=docker.texttechnologylab.org/uce-core-feedback-keycloak-config:0.1.1

# For debugging to test functionality of expiring sessions. (seconds) (No leading spaces!)
# KC_SSO_SESSION_IDLE_TIMEOUT=

# Optional: Realm "Require SSL" setting. Set to `none` to allow plain HTTP logins for local/dev.
# Allowed values: none | external | all
KC_SSL_REQUIRED=external

# `deploy/keycloak-config.sh` derives these during execution; you normally should not set them.
# TOKEN=
# CLIENT_UUID=